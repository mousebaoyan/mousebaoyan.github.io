---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import PageHeader from "../../components/PageHeader.astro";

const tools = await getCollection("tools");
const sorted = tools.filter((t) => !t.data.draft).sort((a, b) =>
  a.data.name.localeCompare(b.data.name, "zh"),
);
const categories = [...new Set(sorted.map((t) => t.data.category))];
---

<BaseLayout
  title="推荐资源 — 四非保研鼠群"
  description="群内整理的保研备战实用资源，包括工具、网站和参考资料。"
>
  <div class="container">
    <PageHeader
      eyebrow="推荐资源"
      title="备战时趁手的资源"
      lead="群友整理的工具、网站和参考资料，覆盖情报收集到材料准备全流程"
    />

    <div class="page-actions">
      <a class="submit-btn" href="https://github.com/mousebaoyan/mousebaoyan.github.io/issues/new?template=resource-submission.yml" target="_blank" rel="noopener">推荐资源</a>
    </div>

    {
      categories.map((cat) => (
        <section class="cat-section">
          <h2 class="cat-section__title">{cat}</h2>
          <div class="tools-grid">
            {sorted
              .filter((t) => t.data.category === cat)
              .map((t) => (
                <ToolCard
                  name={t.data.name}
                  description={t.data.description}
                  category={t.data.category}
                  link={t.data.link}
                  tags={t.data.tags}
                  slug={t.id}
                />
              ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .page-actions {
    margin-bottom: clamp(24px, 4vw, 36px);
  }
  .submit-btn {
    display: inline-block;
    padding: 9px 22px;
    border-radius: var(--r-pill);
    border: 1.5px solid var(--border);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-2);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .submit-btn:hover {
    border-color: var(--blue);
    color: var(--blue);
    background: rgba(0, 113, 227, 0.04);
  }
  .cat-section {
    margin-bottom: clamp(40px, 6vw, 64px);
  }
  .cat-section__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink-2);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line-soft);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }
  @media (max-width: 860px) {
    .tools-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 540px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
