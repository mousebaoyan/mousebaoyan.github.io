---
import { site } from "../site.config";
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="hero__eyebrow">{site.name}</p>
      <h1 class="hero__title">四非也能上岸</h1>
      <p class="hero__sub">给非 985/211 的计算机同学，一个交流保研信息和经验的地方。</p>
      <p class="hero__trust">已经有 1,000+ 名四非同学在群里</p>
    </div>

    <div class="hero__stage" aria-hidden="true">
      <img class="hero__logo" src="/logo.jpg" alt="" width="320" height="320" />
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(110% 90% at 80% 10%, var(--blue-soft) 0%, transparent 55%),
      var(--bg);
    overflow: hidden;
    min-height: calc(100svh - var(--nav-h));
    display: flex;
    align-items: center;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(32px, 6vw, 72px);
    padding-top: clamp(56px, 9vw, 104px);
    padding-bottom: clamp(56px, 9vw, 104px);
  }
  .hero__eyebrow {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--ink-2);
    letter-spacing: -0.01em;
  }
  .hero__title {
    margin-top: 6px;
    font-size: clamp(2.9rem, 7vw, 5.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.02;
  }
  .hero__sub {
    margin-top: 20px;
    max-width: 26ch;
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    font-weight: 500;
    line-height: 1.32;
    color: var(--ink-2);
    letter-spacing: -0.015em;
  }
  .hero__trust {
    margin-top: clamp(28px, 4vw, 40px);
    font-size: 1.02rem;
    color: var(--ink-3);
  }

  .hero__stage {
    position: relative;
    display: grid;
    place-items: center;
  }
  .hero__stage::before {
    content: "";
    position: absolute;
    width: clamp(300px, 42vw, 460px);
    aspect-ratio: 1;
    background: radial-gradient(closest-side, rgba(0, 113, 227, 0.16), transparent 70%);
    filter: blur(8px);
  }
  .hero__logo {
    position: relative;
    width: clamp(200px, 34vw, 340px);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.28);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: clamp(28px, 6vw, 40px);
    }
    .hero__sub {
      margin-inline: auto;
    }
    .hero__stage {
      order: -1;
    }
    .hero__logo {
      width: clamp(180px, 50vw, 260px);
    }
  }
</style>
