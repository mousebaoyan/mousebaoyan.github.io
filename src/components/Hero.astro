---
import { site } from "../site.config";
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="hero__eyebrow">{site.name}</p>
      <h1 class="hero__title">四非也能上岸</h1>
      <p class="hero__sub">
        给非 985/211/双一流 的计算机同学，一个交流保研信息和经验的地方
      </p>
      <p class="hero__trust">已经有 1,000+ 名四非同学在群里</p>
    </div>

    <div class="hero__stage" aria-hidden="true">
      <img class="hero__logo" src="/logo.jpg" alt="" width="320" height="320" />
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(
        ellipse 90% 60% at 75% 15%,
        rgba(0, 113, 227, 0.08) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse 70% 50% at 20% 80%,
        rgba(110, 86, 207, 0.06) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse 50% 50% at 60% 70%,
        rgba(232, 89, 12, 0.03) 0%,
        transparent 50%
      ),
      var(--bg);
    overflow: hidden;
    min-height: calc(100svh - var(--nav-h));
    display: flex;
    align-items: center;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(32px, 6vw, 72px);
    padding-top: clamp(56px, 9vw, 104px);
    padding-bottom: clamp(56px, 9vw, 104px);
  }
  .hero__eyebrow {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 600;
    color: var(--ink-2);
    letter-spacing: -0.01em;
  }
  .hero__title {
    margin-top: 6px;
    font-size: clamp(2.9rem, 7vw, 5.2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.02;
    background: linear-gradient(
      135deg,
      var(--ink) 40%,
      var(--blue) 80%,
      var(--purple) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__sub {
    margin-top: 20px;
    max-width: 26ch;
    font-size: clamp(1.25rem, 2.6vw, 1.7rem);
    font-weight: 500;
    line-height: 1.32;
    color: var(--ink-2);
    letter-spacing: -0.015em;
  }
  .hero__trust {
    margin-top: clamp(28px, 4vw, 40px);
    font-size: 1.02rem;
    color: var(--ink-3);
  }
  .hero__trust::before {
    content: "";
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34c759;
    margin-right: 8px;
    vertical-align: middle;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .hero__stage {
    position: relative;
    display: grid;
    place-items: center;
  }
  .hero__stage::before {
    content: "";
    position: absolute;
    width: clamp(340px, 46vw, 520px);
    aspect-ratio: 1;
    background:
      radial-gradient(closest-side, rgba(0, 113, 227, 0.14), transparent 50%),
      radial-gradient(
        closest-side at 60% 60%,
        rgba(110, 86, 207, 0.1),
        transparent 60%
      );
    filter: blur(20px);
    animation: hero-glow 6s ease-in-out infinite alternate;
  }

  @keyframes hero-glow {
    from {
      transform: scale(1);
      opacity: 0.8;
    }
    to {
      transform: scale(1.08);
      opacity: 1;
    }
  }
  .hero__logo {
    position: relative;
    width: clamp(200px, 34vw, 340px);
    height: clamp(200px, 34vw, 340px);
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.28);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: clamp(28px, 6vw, 40px);
    }
    .hero__sub {
      margin-inline: auto;
    }
    .hero__stage {
      order: -1;
    }
    .hero__logo {
      width: clamp(180px, 50vw, 260px);
      height: clamp(180px, 50vw, 260px);
    }
  }
</style>
