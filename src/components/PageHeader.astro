---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<div class="page-header">
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h1 class="page-header__title">{title}</h1>
  {lead && <p class="page-header__lead">{lead}</p>}
</div>

<style>
  .page-header {
    padding: clamp(48px, 8vw, 96px) 0 clamp(32px, 5vw, 56px);
    max-width: 640px;
  }
  .page-header__title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-top: 12px;
  }
  .page-header__lead {
    margin-top: 16px;
    font-size: 1.1rem;
    color: var(--ink-2);
    line-height: 1.5;
  }
</style>
