---
// 内联 SVG 图标（Lucide 风格描边），不用 emoji
const features = [
  {
    key: "info",
    title: "保研信息",
    desc: "夏令营 / 预推免开营、是否卡四非、报名截止时间，群里都会同步",
  },
  {
    key: "tools",
    title: "推荐资源",
    desc: "夏令营网站、实用工具、简历模板……群友整理的资源，少踩坑",
  },
  {
    key: "experience",
    title: "上岸经验",
    desc: "四非学长学姐的复盘，背景、套磁、面试这些细节，比鸡汤实在",
  },
  {
    key: "community",
    title: "一起交流",
    desc: "一群同样出身普通院校的同学，互相答疑、交换信息，少走点弯路",
  },
];
---

<section class="section section--alt section--full" id="about">
  <div class="container">
    <div class="section__head section__head--center">
      <span class="eyebrow">这里有什么</span>
      <h2 class="section__title">
        四非保研难，<br class="mobile-br" />但不是没办法
      </h2>
      <p class="section__lead">
        出身不占优势的时候，信息和经验往往是能补上的那块
      </p>
    </div>

    <div class="bento">
      {
        features.map((f, i) => (
          <article
            class={`bento__card reveal reveal--delay-${i + 1}`}
          >
            <span class="bento__icon" aria-hidden="true">
              {f.key === "info" && (
                <svg class="icon" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 8h.01M11 12h1v4h1" />
                </svg>
              )}
              {f.key === "experience" && (
                <svg class="icon" viewBox="0 0 24 24">
                  <path d="M6 2.5h8l4 4v15H6z" />
                  <path d="M14 2.5v4h4M9 13h6M9 17h6" />
                </svg>
              )}
              {f.key === "community" && (
                <svg class="icon" viewBox="0 0 24 24">
                  <circle cx="9" cy="8" r="3.2" />
                  <path d="M3.5 20a5.5 5.5 0 0 1 11 0M16 5.2a3 3 0 0 1 0 5.8M20.5 20a5.2 5.2 0 0 0-4-5" />
                </svg>
              )}
              {f.key === "tools" && (
                <svg class="icon" viewBox="0 0 24 24">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3-3a6 6 0 0 1-7.36 7.68L7.6 20.7A2.12 2.12 0 0 1 4.5 17.6l6.37-6.14a6 6 0 0 1 3.83-5.2z" />
                </svg>
              )}
            </span>
            <div class="bento__body">
              <h3 class="bento__title">{f.title}</h3>
              <p class="bento__desc">{f.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }
  .bento__card {
    grid-column: span 1;
    display: flex;
    flex-direction: column;
    gap: 18px;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-lg);
    padding: clamp(26px, 3vw, 40px);
    min-height: 220px;
    box-shadow: var(--shadow-card);
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s ease;
  }
  .bento__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card-hover);
    border-color: rgba(0, 113, 227, 0.15);
  }
  .bento__icon {
    display: inline-grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--gradient-accent-soft);
    color: var(--blue);
  }
  .bento__card:nth-child(2) .bento__icon,
  .bento__card:nth-child(3) .bento__icon {
    background: var(--purple-soft);
    color: var(--purple);
  }
  .bento__body {
    margin-top: auto;
  }
  .bento__title {
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    letter-spacing: -0.02em;
  }
  .bento__desc {
    margin-top: 8px;
    color: var(--ink-2);
    font-size: 1.04rem;
    line-height: 1.45;
    max-width: 46ch;
  }

  .mobile-br {
    display: none;
  }

  @media (max-width: 860px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
    .bento__card,
    .bento__card--wide {
      grid-column: span 1;
      min-height: 0;
    }
  }
  @media (max-width: 540px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .mobile-br {
      display: inline;
    }
  }
</style>
