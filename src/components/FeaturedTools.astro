---
import { getCollection } from "astro:content";
import ToolCard from "./ToolCard.astro";

const tools = await getCollection("tools");
const featured = tools.filter((t) => t.data.featured && !t.data.draft).slice(0, 3);
---

{featured.length > 0 && (
  <section class="section featured-tools">
    <div class="container">
      <div class="featured-tools__head">
        <div>
          <span class="eyebrow">推荐资源</span>
          <h2 class="section__title">备战时趁手的资源</h2>
        </div>
        <a class="link-arrow" href="/resources">
          查看全部
          <svg viewBox="0 0 24 24"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="tools-grid">
        {featured.map((t) => (
          <ToolCard
            name={t.data.name}
            description={t.data.description}
            category={t.data.category}
            link={t.data.link}
            tags={t.data.tags}
            slug={t.id}
          />
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .featured-tools {
    border-top: 1px solid var(--line-soft);
  }

  .featured-tools__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: clamp(28px, 4vw, 40px);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }
  @media (max-width: 860px) {
    .tools-grid { grid-template-columns: 1fr 1fr; }
    .featured-tools__head { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 540px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
